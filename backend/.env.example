DATABASE_URL=sqlite:///./localhub.db
# JSON array of exact frontend origins. Do not include paths.

# 실제 배포 환경에서는 CORS_ORIGINS를 실제 프론트엔드 도메인으로 변경해야 함.
CORS_ORIGINS=["http://localhost:5173"]

# 챗봇 RAG
OPENAI_API_KEY=
